# Copy to `.env.local` and fill in values. Next.js loads `.env.local` automatically.

# --- Developer login (/developer) ---
# The developer portal is HIDDEN by default in production builds.
# To expose it, set to exactly `true` BEFORE running `next build` (the value
# is inlined into the client bundle at build time — changing it at runtime
# will NOT re-show the route).
# Local `next dev` always shows it so this var is optional during development.
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

# Comma-separated Gmail addresses allowed to open /developer (client + Functions).
# When empty, any Google sign-in is accepted (not recommended for production).
# NEXT_PUBLIC_DEVELOPER_GOOGLE_EMAIL_ALLOWLIST=you@gmail.com
# DEVELOPER_GOOGLE_EMAIL_ALLOWLIST=you@gmail.com

# --- Optional: AI features (parse students/schedule, theme generator) ---
# These API routes are gated: caller must be an admin/teacher of a school
# (see src/lib/apiAuth.ts). Missing keys simply disable the AI features.
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Tech support: staff "Send to WhatsApp" in Help panel ---
# Option A — Twilio WhatsApp (recommended for production):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1xxxxxxxxxx
# TECH_SUPPORT_WHATSAPP_TO=whatsapp:+1xxxxxxxxxx
# Option B — CallMeBot (link your phone and get a key at callmebot.com):
# CALLMEBOT_APIKEY=
# Optional if your key needs an explicit number: CALLMEBOT_PHONE=1xxxxxxxxxx

# --- Local Firebase Emulator Suite ---
# Copy your production Firebase Config as usual, then enable this so the Next.js app talks to
# emulators instead of *.googleapis.com (Auth, Firestore, Functions callables e.g. enrollStudentFace).
# Terminal 1 (from repo root): firebase emulators:start
# Terminal 2: NEXT_PUBLIC_FIREBASE_EMULATORS=1 next dev
# Optional port overrides must match firebase.json ("emulators" block): NEXT_PUBLIC_FIREBASE_EMULATOR_HOST,
# NEXT_PUBLIC_FIREBASE_EMULATOR_AUTH_PORT, NEXT_PUBLIC_FIREBASE_EMULATOR_FIRESTORE_PORT,
# NEXT_PUBLIC_FIREBASE_EMULATOR_FUNCTIONS_PORT, NEXT_PUBLIC_FIREBASE_EMULATOR_STORAGE_PORT
# NEXT_PUBLIC_FIREBASE_EMULATORS=

# --- Local Functions Emulator Only ---
# Useful when developing callable code against the normal Firebase Auth/Firestore project.
# Terminal 1 (from repo root): firebase emulators:start --only functions
# Terminal 2: NEXT_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR=1 next dev
# NEXT_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR=

# --- Optional ---
# Shown in the portal footer; defaults to the value in next.config.js if unset.
# NEXT_PUBLIC_VERSION=

# --- Production auth safety ---
# Leave unset for normal production once /api/auth/session is healthy.
# Emergency rollback switch: set to 1 and redeploy Hosting if school clients are
# being bounced from /{school}/portal back to /login because session-cookie
# middleware is failing. This does not bypass the school passcode/callable gate.
# DISABLE_AUTH_SESSION_EDGE=1

# Set to 1 in CI/staging when you intentionally test strict edge session cookies.
# AUTH_SESSION_EDGE_ENFORCEMENT=1

# Live auth smoke test inputs (`npm run test:live-auth`).
# LIVE_AUTH_BASE_URL=https://levelupenterprises.education
# LIVE_AUTH_SCHOOL_ID=yeshiva
# LIVE_AUTH_PASSCODE=1234
# LIVE_AUTH_REQUIRE_SESSION_COOKIE=0
