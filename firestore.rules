
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin(schoolId) {
      let rolesPath = /databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid);
      let roleDocData = get(rolesPath).data;
      // This is a safer check. It ensures roleDocData is not null before trying to access .role
      return isAuth() && roleDocData != null && roleDocData.role == 'admin';
    }

    function teacherRoleData(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId)/roles_teacher/$(request.auth.uid)).data;
    }

    function isTeacher(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_teacher/$(request.auth.uid))
        && teacherRoleData(schoolId).role == 'teacher';
    }

    function isSecretary(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_secretary/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_secretary/$(request.auth.uid)).data.role == 'secretary';
    }

    function isPrizeClerk(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_prizeClerk/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_prizeClerk/$(request.auth.uid)).data.role == 'prizeClerk';
    }

    function isReports(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_reports/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_reports/$(request.auth.uid)).data.role == 'reports';
    }

    function isLibrarian(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_librarian/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_librarian/$(request.auth.uid)).data.role == 'librarian';
    }

    function isOffice(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_office/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_office/$(request.auth.uid)).data.role == 'office';
    }

    function isHouseCoordinator(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_houseCoordinator/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/roles_houseCoordinator/$(request.auth.uid)).data.role == 'houseCoordinator';
    }

    function canAccessOffice(schoolId) {
      return isDeveloper() || isAdmin(schoolId) || isOffice(schoolId);
    }

    function staffAccountIsOfficeRole(data) {
      return data.role == 'office';
    }

    // A student who has entered a school kiosk session via the Cloud Function.
    function hasKioskSession(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/kioskMembers/$(request.auth.uid));
    }

    // School access passcode succeeded (portal chooser / staff hub before role sign-in).
    function hasAnonymousPortalSession(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/anonymousPortalSessions/$(request.auth.uid));
    }

    // Signed in via student home portal (custom token uid == student doc id).
    function hasStudentPortalSession(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/studentPortalSessions/$(request.auth.uid));
    }

    // Staff, kiosk, or school-portal lobby (read-mostly admin UI before admin/teacher passcode).
    // Rewards / kiosk / portal hub — office staff use separate office* collections only.
    function isSchoolMember(schoolId) {
      return isAdmin(schoolId) || isTeacher(schoolId) || isSecretary(schoolId)
        || isPrizeClerk(schoolId) || isReports(schoolId) || isLibrarian(schoolId) || isHouseCoordinator(schoolId) || isDeveloper()
        || hasKioskSession(schoolId) || hasAnonymousPortalSession(schoolId);
    }

    function isLibraryCheckoutActivity() {
      return isAuth()
        && request.resource.data.keys().hasOnly(['desc', 'amount', 'date'])
        && request.resource.data.desc is string
        && request.resource.data.desc.matches('^(Checked out|Returned) library item: .*')
        && request.resource.data.amount == 0
        && request.resource.data.date is number;
    }

    function isLibraryCheckoutUpdate() {
      return isAuth()
        && (
          (
            resource.data.status == 'available'
            && request.resource.data.status == 'checked_out'
            && request.resource.data.checkedOutTo is string
            && request.resource.data.checkedOutAt is number
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'checkedOutTo', 'checkedOutAt', 'dueAt'])
          )
          || (
            resource.data.status == 'checked_out'
            && request.resource.data.status == 'available'
            && request.resource.data.checkedOutTo == null
            && request.resource.data.checkedOutAt == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'checkedOutTo', 'checkedOutAt', 'dueAt'])
          )
        );
    }

    function teacherIdFor(schoolId) {
      return teacherRoleData(schoolId).teacherId;
    }

    function isTeacherSelf(schoolId, teacherId) {
      return isTeacher(schoolId) && teacherIdFor(schoolId) == teacherId;
    }

    function isTeacherOwnedCreate(schoolId) {
      return isTeacher(schoolId)
        && request.resource.data.teacherId is string
        && request.resource.data.teacherId == teacherIdFor(schoolId);
    }

    function isTeacherOwnedPrizeCreate(schoolId) {
      return isTeacher(schoolId)
        && (
          (request.resource.data.teacherId is string && request.resource.data.teacherId == teacherIdFor(schoolId))
          || (request.resource.data.teacherIds is list && teacherIdFor(schoolId) in request.resource.data.teacherIds)
        );
    }

    function isTeacherOwnedPrizeUpdate(schoolId) {
      return isTeacher(schoolId)
        && (
          (resource.data.teacherId is string && resource.data.teacherId == teacherIdFor(schoolId))
          || (resource.data.teacherIds is list && teacherIdFor(schoolId) in resource.data.teacherIds)
        )
        && (
          (request.resource.data.teacherId is string && request.resource.data.teacherId == teacherIdFor(schoolId))
          || (request.resource.data.teacherIds is list && teacherIdFor(schoolId) in request.resource.data.teacherIds)
        );
    }

    function isDeveloper() {
      return isAuth() && exists(/databases/$(database)/documents/appConfig/developerAllowlist)
        && 'uids' in get(/databases/$(database)/documents/appConfig/developerAllowlist).data
        && request.auth.uid in get(/databases/$(database)/documents/appConfig/developerAllowlist).data.uids;
    }

    // Global app configuration (e.g. app logo, name, tagline)
    match /appConfig/{docId} {
      // Public read so login page can show app logo before user signs in.
      allow read: if docId == 'global';
      // Only developers can read the allowlist itself.
      allow read: if docId == 'developerAllowlist' && isDeveloper();
      allow write: if false;
    }

    // Minimal tenant metadata for student portal and public deep links (no secrets).
    // get-by-id only: list is forbidden so clients cannot enumerate other schools.
    match /schoolPublic/{schoolId} {
      allow get: if isAuth();
      allow list: if false;
      allow create, update: if isAdmin(schoolId) || isDeveloper()
        || (
          isTeacher(schoolId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['appSettings', 'updatedAt', 'active'])
        );
      allow delete: if isDeveloper();
    }

    // Collection-group query used by the developer console to find active
    // remote screen-share sessions across schools.
    match /{path=**}/supportSessions/{sessionId} {
      allow read: if isDeveloper();
    }

    // School screen snapshots (kiosk + student portal) for the developer console.
    match /{path=**}/schoolScreens/{deviceId} {
      allow read: if isDeveloper();
    }
    
    match /schools/{schoolId} {
      allow read: if isDeveloper() || isAdmin(schoolId) || isTeacher(schoolId) || isSecretary(schoolId) || isPrizeClerk(schoolId) || isReports(schoolId) || isLibrarian(schoolId) || isOffice(schoolId) || isHouseCoordinator(schoolId);
      allow create: if isDeveloper();
      allow delete: if isAdmin(schoolId) || isDeveloper();
      // Teachers may adjust raffle knobs (stored in appSettings) without full admin rights.
      allow update: if isAdmin(schoolId) || isDeveloper()
        || (
          isTeacher(schoolId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appSettings', 'updatedAt'])
        );

      // Private school record: staff of this school or a platform developer.
      // Students and anonymous users use `schoolPublic/{schoolId}` instead.

      match /students/{studentId} {
        allow read: if isSchoolMember(schoolId)
          || (isAuth() && request.auth.uid == studentId && hasStudentPortalSession(schoolId));
        allow create, delete: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId) || isTeacher(schoolId) || isPrizeClerk(schoolId) || isDeveloper()
          || (
            isHouseCoordinator(schoolId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['houseId', 'updatedAt'])
          );

        match /activities/{activityId} {
          allow read: if isSchoolMember(schoolId)
            || (isAuth() && request.auth.uid == studentId && hasStudentPortalSession(schoolId));
          allow create: if isAdmin(schoolId) || isTeacher(schoolId) || isPrizeClerk(schoolId) || isDeveloper() || isLibraryCheckoutActivity();
          allow update: if isAdmin(schoolId) || isTeacher(schoolId) || isPrizeClerk(schoolId);
          allow delete: if isAdmin(schoolId);
        }

        match /homeworkSubmissions/{assignmentId} {
          allow read, write: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        }
      }
      
      match /teachers/{teacherId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isPrizeClerk(schoolId) || isReports(schoolId) || isOffice(schoolId) || isHouseCoordinator(schoolId) || isDeveloper();
        allow create, delete: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId)
          || (
            isHouseCoordinator(schoolId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['houseParentHouseIds'])
          )
          || (
            isTeacherSelf(schoolId, teacherId)
            && (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['spentThisMonth'])
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['spentThisMonth', 'budgetWindowKey'])
            )
          );
      }

      // Per-teacher attendance configuration (stored under each teacher document).
      match /teachers/{teacherId}/attendanceConfig/{docId} {
        allow read, write: if isAdmin(schoolId) || isDeveloper() || isTeacherSelf(schoolId, teacherId);
      }

      // Per-teacher attendance reward rules (teacher-managed).
      match /teachers/{teacherId}/attendanceRewards/{ruleId} {
        allow read, write: if isAdmin(schoolId) || isDeveloper() || isTeacherSelf(schoolId, teacherId);
      }

      match /homework/{assignmentId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        allow write: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
      }
      
      match /classes/{classId} {
        allow read: if isSchoolMember(schoolId);
        allow write: if isAdmin(schoolId) || isTeacher(schoolId);
      }

      match /houses/{houseId} {
        allow read: if isSchoolMember(schoolId) || hasStudentPortalSession(schoolId);
        allow write: if isAdmin(schoolId) || isTeacher(schoolId) || isHouseCoordinator(schoolId) || isDeveloper();
      }
      
      match /categories/{categoryId} {
        // Categories are used by teachers in the UI.
        allow read: if isSchoolMember(schoolId) || hasStudentPortalSession(schoolId);
        allow create: if isAdmin(schoolId) || isDeveloper()
          || isTeacherOwnedCreate(schoolId);
        allow update: if isAdmin(schoolId) || isDeveloper()
          || (
            isTeacher(schoolId)
            && resource.data.teacherId is string
            && resource.data.teacherId == teacherIdFor(schoolId)
            && request.resource.data.teacherId is string
            && request.resource.data.teacherId == teacherIdFor(schoolId)
          );
        allow delete: if isAdmin(schoolId) || isDeveloper();
      }

      match /achievements/{achievementId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId) || isDeveloper();
        allow write: if isAdmin(schoolId);
      }

      match /badges/{badgeId} {
        // Read: staff can load badge definitions and earned badges.
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId) || isDeveloper()
          || hasStudentPortalSession(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /goals/{goalId} {
        allow read: if isSchoolMember(schoolId) || hasStudentPortalSession(schoolId);
        allow create, update, delete: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
      }

      match /behaviorNotes/{noteId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId) || isDeveloper();
        allow create: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        allow update, delete: if isAdmin(schoolId) || isDeveloper();
      }

      match /classroomAwards/{awardId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId) || isDeveloper();
        allow create: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        allow update, delete: if isAdmin(schoolId) || isDeveloper();
      }

      match /bulletinBoardIncentives/{incentiveId} {
        // Bulletin board incentives are intentionally readable after auth
        // (e.g. demo / kiosk flows) even before role/kioskMember docs exist.
        allow read: if isAuth();
        allow create, update, delete: if isAdmin(schoolId) || isDeveloper();
      }

      // Celebration posts (e.g. birthdays) written by Cloud Functions only.
      // Same read stance as bulletinBoardIncentives: any authenticated user can
      // load the board (school portal / demo flows before role docs exist).
      match /bulletinBoardPosts/{postId} {
        allow read: if isAuth();
        allow create, update, delete: if false;
      }

      // Printed pickup vouchers (VR… barcodes) — written by Cloud Functions; kiosk reads for fulfillment.
      match /prizeVoucherByCode/{code} {
        allow read: if isSchoolMember(schoolId) || hasKioskSession(schoolId) || hasStudentPortalSession(schoolId);
        allow write: if false;
      }

      match /prizes/{prizeId} {
        allow read: if isSchoolMember(schoolId) || hasStudentPortalSession(schoolId);
        allow create: if isAdmin(schoolId) || isTeacherOwnedPrizeCreate(schoolId);
        allow update: if isAdmin(schoolId) || isTeacherOwnedPrizeUpdate(schoolId)
          || (
            isPrizeClerk(schoolId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockCount', 'inStock'])
          );
        allow delete: if isAdmin(schoolId)
          || (
            isTeacher(schoolId)
            && (
              (resource.data.teacherId is string && resource.data.teacherId == teacherIdFor(schoolId))
              || (resource.data.teacherIds is list && teacherIdFor(schoolId) in resource.data.teacherIds)
            )
          );
      }

      match /coupons/{couponId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isSecretary(schoolId) || isReports(schoolId) || isDeveloper();
        allow create, update: if isAdmin(schoolId) || isTeacher(schoolId) || isSecretary(schoolId) || isDeveloper();
        allow delete: if isAdmin(schoolId) || isDeveloper();
      }

      match /library/{itemId} {
        allow read: if isSchoolMember(schoolId) || hasStudentPortalSession(schoolId);
        allow create, delete: if isAdmin(schoolId) || isTeacher(schoolId) || isLibrarian(schoolId) || isDeveloper();
        allow update: if isAdmin(schoolId) || isTeacher(schoolId) || isLibrarian(schoolId) || isDeveloper() || isLibraryCheckoutUpdate();
      }

      // Desk staff logins. Admins manage all roles; office staff may manage office-role accounts only.
      match /staffAccounts/{accountId} {
        allow read: if isAdmin(schoolId) || isDeveloper() || isOffice(schoolId);
        allow create: if isAdmin(schoolId) || isDeveloper()
          || (isOffice(schoolId) && staffAccountIsOfficeRole(request.resource.data));
        allow update: if isAdmin(schoolId) || isDeveloper()
          || (isOffice(schoolId)
            && staffAccountIsOfficeRole(resource.data)
            && staffAccountIsOfficeRole(request.resource.data));
        allow delete: if isAdmin(schoolId) || isDeveloper()
          || (isOffice(schoolId) && staffAccountIsOfficeRole(resource.data));
      }

      match /officeSettings/{docId} {
        allow read, write: if canAccessOffice(schoolId);
      }
      
      match /roles_admin/{uid} {
        // Admin roles are provisioned ONLY by trusted backend code (Admin SDK).
        // Clients may read their own role doc to confirm access after login.
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_teacher/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_secretary/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_prizeClerk/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_reports/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_librarian/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_office/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_houseCoordinator/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /officeStudents/{studentId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /officeClasses/{classId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /officeTeachers/{teacherId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /officeGradeEntries/{entryId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /officeBillingAccounts/{accountId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /officeInvoices/{invoiceId} {
        allow read, write: if canAccessOffice(schoolId);
      }

      match /anonymousPortalSessions/{uid} {
        allow read, write: if false;
      }

      match /studentPortalMembers/{uid} {
        allow read, write: if false;
      }

      match /studentPortalSessions/{studentId} {
        allow read: if isAuth() && request.auth.uid == studentId;
        allow write: if false;
      }

      match /studentPortalDevices/{deviceId} {
        allow read, write: if false;
      }

      // Passcode stored here; never readable by clients.
      // The Cloud Function verifySchoolPasscode reads this via the admin SDK.
      match /secrets/{docId} {
        allow read: if false;
        allow write: if isAdmin(schoolId);
      }

      match /backups/{backupId} {
        allow read: if isAdmin(schoolId) || isDeveloper();
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      match /supportSessions/{sessionId} {
        allow read: if isDeveloper()
          || isAdmin(schoolId)
          || (isAuth() && resource.data.requesterUid == request.auth.uid);
        allow create: if isAuth()
          && request.resource.data.schoolId == schoolId
          && request.resource.data.requesterUid == request.auth.uid
          && request.resource.data.kind == 'screen-share'
          && request.resource.data.status in ['waiting', 'sharing'];
        allow update: if isDeveloper()
          || (
            isAuth()
            && resource.data.requesterUid == request.auth.uid
            && request.resource.data.requesterUid == resource.data.requesterUid
            && request.resource.data.schoolId == resource.data.schoolId
          );
        allow delete: if isDeveloper();

        match /{candidateCollection}/{candidateId} {
          allow read, write: if isDeveloper()
            || (
              isAuth()
              && get(/databases/$(database)/documents/schools/$(schoolId)/supportSessions/$(sessionId)).data.requesterUid == request.auth.uid
            );
        }
      }

      // Live school screen snapshots (written by server API; readable by developer + school admin).
      match /schoolScreens/{deviceId} {
        allow read: if isDeveloper() || isAdmin(schoolId);
        allow write: if false;
        allow delete: if isDeveloper();
      }

      match /attendance/{docId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId);
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      // Universal period definitions (created/managed by admin).
      match /periods/{periodId} {
        allow read: if isSchoolMember(schoolId);
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      match /attendanceLog/{entryId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId);
        // Attendance logs are audit records and point-award evidence. They are
        // created by the trusted Cloud Function via the Admin SDK.
        allow create: if false;
        allow update, delete: if isAdmin(schoolId);
      }

      match /bathroomActive/{studentId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId);
        allow create, update, delete: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
      }

      match /bathroomLog/{entryId} {
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isReports(schoolId);
        allow create: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        allow update, delete: if isAdmin(schoolId) || isDeveloper();
      }

      // Face auth descriptors are private and only accessible via Admin SDK / Cloud Functions.
      match /faceAuth/{studentId} {
        allow read, write: if false;
      }
    }

    // Outbound notification queues (created by Cloud Functions; extensions / workers deliver).
    match /mail/{mailId} {
      allow read: if isDeveloper()
        || (
          isAuth()
          && resource.data.schoolId is string
          && isAdmin(resource.data.schoolId)
        );
      allow write: if false;
    }

    match /sms/{smsId} {
      allow read: if isDeveloper()
        || (
          isAuth()
          && resource.data.schoolId is string
          && isAdmin(resource.data.schoolId)
        );
      allow write: if isDeveloper()
        || (
          isAuth()
          && request.resource.data.schoolId is string
          && canAccessOffice(request.resource.data.schoolId)
        );
    }

    match /whatsapp/{waId} {
      allow read: if isDeveloper()
        || (
          isAuth()
          && resource.data.schoolId is string
          && isAdmin(resource.data.schoolId)
        );
      allow write: if isDeveloper()
        || (
          isAuth()
          && request.resource.data.schoolId is string
          && canAccessOffice(request.resource.data.schoolId)
        );
    }

    // Public marketing contact form (written via Admin SDK only).
    match /siteContactSubmissions/{submissionId} {
      allow read: if isDeveloper();
      allow write: if false;
    }
  }
}
