
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin(schoolId) {
      let rolesPath = /databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid);
      let roleDocData = get(rolesPath).data;
      // This is a safer check. It ensures roleDocData is not null before trying to access .role
      return isAuth() && roleDocData != null && roleDocData.role == 'admin';
    }

    function isTeacher(schoolId) {
      let rolesPath = /databases/$(database)/documents/schools/$(schoolId)/roles_teacher/$(request.auth.uid);
      let roleDocData = get(rolesPath).data;
      return isAuth() && roleDocData != null && roleDocData.role == 'teacher';
    }

    function isDeveloper() {
      return isAuth() && exists(/databases/$(database)/documents/appConfig/global)
        && 'developerUids' in get(/databases/$(database)/documents/appConfig/global).data
        && request.auth.uid in get(/databases/$(database)/documents/appConfig/global).data.developerUids;
    }

    // Global app configuration (e.g. app logo, name, tagline)
    match /appConfig/{docId} {
      // Public read so login page can show app logo before user signs in.
      allow read: if true;
      allow write: if false;
    }

    match /schools/{schoolId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin(schoolId);

      // Read: any authenticated user (access control enforced at the
      // application layer via passcode — the school URL + passcode gate
      // prevents unauthorized UI access).
      // Write: only provisioned admins.

      match /students/{studentId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);

        match /activities/{activityId} {
          allow read: if isAdmin(schoolId);
          allow write: if isAdmin(schoolId);
        }
      }

      match /teachers/{teacherId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      // Per-teacher attendance configuration (stored under each teacher document).
      match /teachers/{teacherId}/attendanceConfig/{docId} {
        // Admins and developers manage all configs. Any teacher provisioned
        // in this school may also read/write (the UI only exposes their own
        // teacherId, and callable functions are used for cross-teacher ops).
        allow read, write: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
      }

      // Per-teacher attendance reward rules (teacher-managed).
      match /teachers/{teacherId}/attendanceRewards/{ruleId} {
        // Read is open to signed-in users because the student portal
        // needs to display the rules tied to their class's teacher.
        allow read: if isAuth();
        // Writes: admins, provisioned teachers for this school, or developer.
        allow write: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
      }

      match /classes/{classId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /categories/{categoryId} {
        // Categories are used by teachers in the UI; allow authenticated users to read.
        // Writes: admins or developers can write freely. Teachers may only write
        // categories tagged with a teacherId AND must have a verified teacher role.
        allow read: if isAuth();
        allow write: if isAdmin(schoolId) || isDeveloper()
          || (isTeacher(schoolId)
              && request.resource.data.teacherId is string
              && request.resource.data.teacherId.size() > 0);
      }

      match /achievements/{achievementId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /badges/{badgeId} {
        // Read: any authenticated user (so teachers/students can load badge definitions and earned badges).
        allow read: if request.auth != null;
        allow write: if isAdmin(schoolId);
      }

      match /prizes/{prizeId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /coupons/{couponId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /roles_admin/{uid} {
        // Admin roles are provisioned ONLY by trusted backend code (Admin SDK).
        // Clients may read their own role doc to confirm access after login.
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_teacher/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      // Face login descriptors are biometric identifiers; never accessible to clients.
      // Access is only via Cloud Functions (Admin SDK).
      match /faceAuth/{studentId} {
        allow read, write: if false;
      }

      // Passcode stored here; never readable by clients.
      // The Cloud Function verifySchoolPasscode reads this via the admin SDK.
      match /secrets/{docId} {
        allow read: if false;
        allow write: if isAdmin(schoolId);
      }

      match /backups/{backupId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /attendance/{docId} {
        // Teachers and admins can read attendance docs (e.g. live roster /
        // schedule UI in the teacher portal).
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      // Universal period definitions (created/managed by admin). Every
      // authenticated user of the school app may read so student and teacher
      // portals can render the schedule.
      match /periods/{periodId} {
        allow read: if isAuth();
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      match /attendanceLog/{entryId} {
        // Read: admins and teachers (shown in admin + teacher dashboards).
        allow read: if isAdmin(schoolId) || isTeacher(schoolId) || isDeveloper();
        // Create: anonymous kiosk sign-ins are expected, so any signed-in
        // user may create — but payload must match the expected shape and
        // cannot claim absurd point awards.
        allow create: if isAuth()
          && request.resource.data.keys().hasAll(['studentId', 'signedInAt', 'sessionId'])
          && request.resource.data.studentId is string
          && request.resource.data.studentId.size() > 0
          && request.resource.data.signedInAt is number
          && request.resource.data.sessionId is string
          && (!('pointsAwarded' in request.resource.data)
              || (request.resource.data.pointsAwarded is number
                  && request.resource.data.pointsAwarded >= 0
                  && request.resource.data.pointsAwarded <= 1000));
        allow update, delete: if isAdmin(schoolId) || isDeveloper();
      }
    }
  }
}
