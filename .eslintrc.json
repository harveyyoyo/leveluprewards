{
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": [
    ".next/",
    ".firebase/",
    "functions/",
    "e2e/",
    "node_modules/",
    "public/"
  ],
  "rules": {
    "@next/next/no-img-element": "off",
    "@next/next/no-page-custom-font": "off",
    "react/no-unescaped-entities": "off",
    "react-hooks/exhaustive-deps": "error",
    "no-console": ["warn", { "allow": ["warn", "error", "debug", "info"] }]
  }
}
