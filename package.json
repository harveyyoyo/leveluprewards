{
  "name": "levelup-edu",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "postinstall": "node scripts/copy-face-models.mjs",
    "dev": "node scripts/dev-webpack.cjs",
    "dev:stable": "node scripts/dev-webpack.cjs",
    "dev:webpack": "node scripts/dev-webpack.cjs",
    "dev:plain": "next dev -p 3000",
    "dev:reset": "npm run clean:next && cross-env SKIP_CLEAN_NEXT=1 npm run dev",
    "clean:next": "node scripts/clean-next.cjs",
    "dev:turbo": "node scripts/dev-turbo.cjs",
    "prebuild": "node scripts/copy-face-models.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:firestore-rules": "node scripts/check-firestore-rule-coverage.mjs && npx firebase-tools deploy --only firestore:rules --dry-run",
    "test:permissions": "node e2e/test_no_permission_errors.mjs",
    "predeploy:check": "npm run check:firestore-rules && npm run test:permissions",
    "deploy:hosting:safe": "node scripts/deploy-hosting-safe.mjs",
    "firebase:ssr:prepare": "node scripts/prepare-firebase-framework-deploy.mjs",
    "test:themes": "node scripts/validate-themes.mjs",
    "backup:code": "node scripts/backup-code.mjs",
    "generate:legal-pdfs": "node scripts/generate-legal-pdfs.mjs",
    "generate:legal-pdfs:text": "node scripts/generate-legal-pdfs-from-text.mjs",
    "generate:flyer-pdf": "node scripts/generate-flyer-pdf.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@vladmandic/face-api": "^1.7.15",
    "@zxing/browser": "^0.1.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.475.0",
    "mammoth": "^1.12.0",
    "next": "^14.2.5",
    "openai": "^6.27.0",
    "patch-package": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "react": "18.2.0",
    "react-day-picker": "^9.11.3",
    "react-dom": "18.2.0",
    "react-easy-crop": "^5.0.7",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.1",
    "axe-core": "^4.11.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.19.12",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
